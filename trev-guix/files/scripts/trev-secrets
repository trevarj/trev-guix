#!/usr/bin/env bash
set -euo pipefail

cipher_file="/run/current-system/profile/share/trev-guix/secrets.env.gpg"
plain_file="/etc/trev-local/env"

usage() {
  cat >&2 <<EOF
Usage: trev-secrets unlock [--cipher FILE] [--plain FILE]

Decrypt the committed local secrets file and install it as root-only
system state on the encrypted root filesystem.
EOF
}

die() {
  printf 'trev-secrets: %s\n' "$*" >&2
  exit 1
}

as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  else
    sudo "$@"
  fi
}

sync_timezone() {
  local timezone zoneinfo
  timezone="$(sed -n 's/^TREV_TIMEZONE=//p' "$plain_file" | tail -n 1)"
  timezone="${timezone%\"}"
  timezone="${timezone#\"}"
  timezone="${timezone%\'}"
  timezone="${timezone#\'}"
  [ -n "$timezone" ] || die "TREV_TIMEZONE is missing from $plain_file"

  zoneinfo="/run/current-system/profile/share/zoneinfo/$timezone"
  [ -f "$zoneinfo" ] || die "invalid timezone: $timezone"

  as_root ln -sfn "$zoneinfo" /etc/localtime
}

unlock() {
  local tmp
  [ -f "$cipher_file" ] || die "missing encrypted secrets file: $cipher_file"
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  gpg --quiet --decrypt --output "$tmp" "$cipher_file"
  grep -Eq '^TREV_[A-Z0-9_]+=' "$tmp" || die "decrypted file has no TREV_* entries"

  as_root install -d -m 0700 /etc/trev-local
  as_root install -m 0600 -o root -g root "$tmp" "$plain_file"
  sync_timezone
  printf 'Installed %s and synced timezone.\n' "$plain_file"
}

command="${1:-}"
[ $# -gt 0 ] && shift || true

while [ $# -gt 0 ]; do
  case "$1" in
    --cipher)
      [ $# -ge 2 ] || die "--cipher requires a value"
      cipher_file="$2"
      shift 2
      ;;
    --plain)
      [ $# -ge 2 ] || die "--plain requires a value"
      plain_file="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

case "$command" in
  unlock) unlock ;;
  -h|--help|"") usage; [ -n "$command" ] ;;
  *) die "unknown command: $command" ;;
esac
