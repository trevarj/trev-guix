+static bool
+line_number_current_line_face_distinct_p (struct window *w)
+{
+  /* `line-number-current-line' inherits from `line-number' by default.
+     Compare the realized faces, not the Lisp face specs, so inheritance
+     that produces identical display attributes does not disable the cheap
+     cursor-movement path.  */
+  return (merge_faces (w, Qline_number, 0, DEFAULT_FACE_ID)
+	  != merge_faces (w, Qline_number_current_line, 0, DEFAULT_FACE_ID));
+}
