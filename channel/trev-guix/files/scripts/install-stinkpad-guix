#!/usr/bin/env bash
set -euo pipefail

source_dotfiles_dir="/etc/trev-dotfiles"
source_trev_guix_dir="/etc/trev-guix"
source_channels_file="/etc/guix/channels.scm"
substitute_urls_file="/etc/guix/substitute-urls"
target_dotfiles_dir="/mnt/home/trev/Workspace/dotfiles"
target_trev_guix_dir="/mnt/home/trev/Workspace/trev-guix"
target_workspace_dir="/mnt/home/trev/Workspace"
system_expr="(@ (trev-guix systems stinkpad-niri) %stinkpad-niri)"
target_channels_file="/mnt/home/trev/.config/guix/channels.scm"
guix_load_path_args=(-L "$source_trev_guix_dir/channel" -L "$source_trev_guix_dir/host")

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_root() {
  [ "$(id -u)" -eq 0 ] || die "run this command as root"
}

partition_path() {
  disk="$1"
  number="$2"

  case "$disk" in
    *[0-9]) printf '%sp%s\n' "$disk" "$number" ;;
    *) printf '%s%s\n' "$disk" "$number" ;;
  esac
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

copy_checkout() {
  name="$1"
  source="$2"
  target="$3"

  if [ -e "$target" ]; then
    printf 'Replacing existing %s checkout at %s.\n' "$name" "$target" >&2
    rm -rf "$target"
  else
    printf 'Copying bundled %s checkout to %s.\n' "$name" "$target" >&2
  fi

  mkdir -p "$target"
  cp -aL --no-preserve=ownership "$source/." "$target/"
}

read_channel_string() {
  variable="$1"
  script="$(mktemp)"

  cat > "$script" <<EOF
(define module (resolve-interface '(trev-guix systems stinkpad)))
(display (module-ref module '$variable))
(newline)
EOF

  guix repl -q "${guix_load_path_args[@]}" -- "$script"
  rm -f "$script"
}

require_network() {
  state="$(connmanctl state 2>/dev/null || true)"

  case "$state" in
    *"State = online"*) return 0 ;;
  esac

  printf '%s\n' "$state" >&2
  die "network is not online; connect with connmanctl before installing"
}

require_root

[ -d "$source_dotfiles_dir" ] || die "$source_dotfiles_dir is missing"
[ -d "$source_trev_guix_dir" ] || die "$source_trev_guix_dir is missing"
[ -f "$source_channels_file" ] || die "$source_channels_file is missing"
[ -f "$substitute_urls_file" ] || die "$substitute_urls_file is missing"

if mountpoint -q /mnt; then
  die "/mnt is already mounted; unmount it before running the installer"
fi

for command in awk cat chown connmanctl cp cryptsetup guix id lsblk mkdir \
  mkfs.ext4 mkfs.fat mktemp mkswap mount partprobe passwd sgdisk sleep \
  swapoff swapon rm umount; do
  require_command "$command"
done

substitute_urls="$(awk '{$1=$1; print}' "$substitute_urls_file")"
[ -n "$substitute_urls" ] || die "$substitute_urls_file is empty"
guix_substitute_args=(--substitute-urls="$substitute_urls")

require_network

printf 'Pulling Guix channels from %s.\n' "$source_channels_file" >&2
guix pull "${guix_substitute_args[@]}" -C "$source_channels_file"

GUIX_PROFILE="/root/.config/guix/current"
. "$GUIX_PROFILE/etc/profile"
hash -r

root_uuid="$(read_channel_string root-uuid)"
efi_uuid="$(read_channel_string efi-uuid)"
swap_uuid="$(read_channel_string swap-uuid)"
efi_volume_id="${efi_uuid//-/}"

[ -n "$root_uuid" ] || die "could not read root-uuid from channel"
[ -n "$efi_uuid" ] || die "could not read efi-uuid from channel"
[ -n "$swap_uuid" ] || die "could not read swap-uuid from channel"
[ "${#efi_volume_id}" -eq 8 ] || die "EFI UUID must be an 8 digit FAT volume ID"

printf 'Validating Guix system configuration from the bundled checkout.\n' >&2
guix system build "${guix_substitute_args[@]}" "${guix_load_path_args[@]}" -n -e "$system_expr"

printf '\nCandidate target disks:\n' >&2
mapfile -t disks < <(
  lsblk --noheadings --nodeps --paths --exclude 7,11 \
    --output PATH,TYPE,RM |
    awk '$2 == "disk" && $3 == "0" {print $1}'
)

[ "${#disks[@]}" -gt 0 ] || die "no non-removable target disks found"

for index in "${!disks[@]}"; do
  disk="${disks[$index]}"
  printf '  %d) %s\n' "$((index + 1))" \
    "$(lsblk --nodeps --noheadings --output PATH,SIZE,MODEL "$disk")" >&2
done

printf '\nSelect disk number to WIPE and install Guix System onto: ' >&2
read -r selection

case "$selection" in
  ''|*[!0-9]*) die "invalid disk selection" ;;
esac

if [ "$selection" -lt 1 ] || [ "$selection" -gt "${#disks[@]}" ]; then
  die "invalid disk selection"
fi

disk="${disks[$((selection - 1))]}"
efi_part="$(partition_path "$disk" 1)"
root_part="$(partition_path "$disk" 2)"
swap_part="$(partition_path "$disk" 3)"

printf '\nSelected target disk: %s\n' "$disk" >&2
lsblk "$disk" >&2

printf '\nThis will destroy all data on %s.\n' "$disk" >&2
printf "Type 'WIPE %s' to continue: " "$disk" >&2
read -r confirmation

[ "$confirmation" = "WIPE $disk" ] || die "confirmation did not match"

printf 'Unmounting any stale target mounts.\n' >&2
swapoff "$swap_part" >/dev/null 2>&1 || true
umount -R /mnt >/dev/null 2>&1 || true
cryptsetup close root >/dev/null 2>&1 || true

printf 'Partitioning %s.\n' "$disk" >&2
sgdisk --zap-all "$disk"
sgdisk --new=1:0:+1GiB --typecode=1:EF00 --change-name=1:EFI "$disk"
sgdisk --new=2:0:-8GiB --typecode=2:8300 --change-name=2:cryptroot "$disk"
sgdisk --new=3:0:0 --typecode=3:8200 --change-name=3:swap "$disk"
partprobe "$disk"
sleep 2

[ -b "$efi_part" ] || die "missing EFI partition $efi_part"
[ -b "$root_part" ] || die "missing root partition $root_part"
[ -b "$swap_part" ] || die "missing swap partition $swap_part"

printf 'Formatting EFI partition %s with UUID %s.\n' "$efi_part" "$efi_uuid" >&2
mkfs.fat -F32 -i "$efi_volume_id" "$efi_part"

printf 'Formatting LUKS root %s with UUID %s.\n' "$root_part" "$root_uuid" >&2
cryptsetup luksFormat --type luks2 --uuid "$root_uuid" "$root_part"
cryptsetup open --allow-discards "$root_part" root

printf 'Formatting ext4 root inside /dev/mapper/root.\n' >&2
mkfs.ext4 -F -L root /dev/mapper/root

printf 'Formatting swap partition %s with UUID %s.\n' "$swap_part" "$swap_uuid" >&2
mkswap -U "$swap_uuid" "$swap_part"
swapon "$swap_part"

printf 'Mounting target system at /mnt.\n' >&2
mount /dev/mapper/root /mnt
mkdir -p /mnt/boot/efi
mount "$efi_part" /mnt/boot/efi
mkdir -p "$target_workspace_dir"

copy_checkout dotfiles "$source_dotfiles_dir" "$target_dotfiles_dir"
copy_checkout trev-guix "$source_trev_guix_dir" "$target_trev_guix_dir"

mkdir -p "$(dirname "$target_channels_file")"
cp --no-preserve=ownership "$source_channels_file" "$target_channels_file"

printf 'Installing Guix System target.\n' >&2
guix system init "${guix_substitute_args[@]}" "${guix_load_path_args[@]}" -e "$system_expr" /mnt

printf 'Making copied user files editable by trev.\n' >&2
chown -R 1000:100 "$target_dotfiles_dir"
chown -R 1000:100 "$target_trev_guix_dir"
chown -R 1000:100 "/mnt/home/trev/.config/guix"

printf '\nSet the login password for trev.\n' >&2
passwd -R /mnt trev

printf 'Installation complete. You can reboot after reviewing /mnt if needed.\n' >&2
