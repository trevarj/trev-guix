#!/usr/bin/env bash

set -euo pipefail

mode="${1:---fast}"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  red=$'\033[31m'
  green=$'\033[32m'
  yellow=$'\033[33m'
  blue=$'\033[34m'
  magenta=$'\033[35m'
  cyan=$'\033[36m'
  bold=$'\033[1m'
  reset=$'\033[0m'
else
  red=
  green=
  yellow=
  blue=
  magenta=
  cyan=
  bold=
  reset=
fi

say() {
  printf '%s==>%s %s%s%s\n' "$cyan" "$reset" "$bold" "$1" "$reset"
}

ok() {
  printf '%sok%s  %s\n' "$green" "$reset" "$1"
}

warn() {
  printf '%swarn%s  %s\n' "$yellow" "$reset" "$1"
}

die() {
  printf '%sfail%s %s\n' "$red" "$reset" "$1" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

run() {
  local title="$1"
  shift

  say "$title"
  printf '%s+%s %s\n' "$blue" "$reset" "$*"
  "$@"
  ok "$title"
}

run_lint() {
  local tmp clean exit_status

  tmp="$(mktemp -t trev-guix-lint.XXXXXX)"
  say "Lint package metadata, derivations, and formatting"
  printf '%s+%s guix lint %s --no-network %s\n' "$blue" "$reset" "${guix_load_path_args[*]}" "${expr_args[*]}"

  set +e
  guix lint "${guix_load_path_args[@]}" --no-network "${expr_args[@]}" >"$tmp" 2>&1
  exit_status="$?"
  set -e

  if [[ -s "$tmp" ]]; then
    sed 's/^/  /' "$tmp"
  fi

  clean="$(sed '/^;;; /d;/^[[:space:]]*$/d' "$tmp")"
  rm -f "$tmp"

  if [[ "$exit_status" -ne 0 ]]; then
    warn "guix lint exited with status $exit_status; continuing"
    return 0
  fi

  if [[ -n "$clean" ]]; then
    warn "guix lint reported issues; continuing"
    return 0
  fi

  ok "Lint package metadata, derivations, and formatting"
}

need git
need guix
need mktemp
need sed

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

declare -a package_files expr_args labels guix_load_path_args extra_load_paths
guix_load_path_args=(-L .)

if [[ -n "${GUIX_EXTRA_LOAD_PATHS:-}" ]]; then
  IFS=':' read -r -a extra_load_paths <<< "$GUIX_EXTRA_LOAD_PATHS"
  for path in "${extra_load_paths[@]}"; do
    [[ -n "$path" ]] && guix_load_path_args+=(-L "$path")
  done
fi

mapfile -t package_files < <(git ls-files 'trev-guix/packages/*.scm')

(( ${#package_files[@]} > 0 )) || die "no package modules found under trev-guix/packages"

for file in "${package_files[@]}"; do
  module="$(sed -n 's/^(define-module (\(.*\)).*/\1/p' "$file" | sed -n '1p')"
  [[ -n "$module" ]] || die "could not read module name from $file"

  declare -a symbols
  mapfile -t symbols < <(sed -n 's/^(define-public \([^[:space:]]*\).*/\1/p' "$file")

  for symbol in "${symbols[@]}"; do
    expr_args+=(-e "(@ ($module) $symbol)")
    labels+=("$module:$symbol")
  done
done

(( ${#labels[@]} > 0 )) || die "no public packages found under trev-guix/packages"

say "Found ${#labels[@]} local package definitions"
for label in "${labels[@]}"; do
  printf '  %s-%s %s\n' "$magenta" "$reset" "$label"
done

case "$mode" in
  --fast)
    run_lint
    run "Evaluate package build graph without building" \
      guix build "${guix_load_path_args[@]}" -n --no-substitutes -k "${expr_args[@]}"
    ;;
  --source)
    run "Fetch package sources and verify declared hashes" \
      guix build "${guix_load_path_args[@]}" --source -k "${expr_args[@]}"
    ;;
  --all)
    run_lint
    run "Evaluate package build graph without building" \
      guix build "${guix_load_path_args[@]}" -n --no-substitutes -k "${expr_args[@]}"
    run "Fetch package sources and verify declared hashes" \
      guix build "${guix_load_path_args[@]}" --source -k "${expr_args[@]}"
    ;;
  *)
    die "usage: scripts/check-channel-packages [--fast|--source|--all]"
    ;;
esac

ok "Channel package checks completed"
